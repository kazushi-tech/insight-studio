{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "review-output.schema.json",
  "title": "Creative Review Output",
  "description": "Banner review / Ad-to-LP review の共通出力 contract。summary, good_points, keep_as_is, improvements, test_ideas, evidence は必須。",
  "type": "object",
  "required": [
    "review_type",
    "summary",
    "good_points",
    "improvements",
    "evidence",
    "target_hypothesis",
    "message_angle",
    "rubric_scores"
  ],
  "properties": {
    "review_type": {
      "type": "string",
      "enum": ["banner_review", "ad_lp_review"],
      "description": "レビュー種別"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "レビュー全体の要約（1-3 文）"
    },
    "product_identification": {
      "type": "string",
      "description": "画像から特定された製品・ブランド・キャンペーン名"
    },
    "good_points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/review_point"
      },
      "description": "良い点。必ず 1 件以上"
    },
    "keep_as_is": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/review_point"
      },
      "description": "変えない方がよい要素（任意）"
    },
    "improvements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/improvement_point"
      },
      "description": "改善提案。行動可能な粒度"
    },
    "test_ideas": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/test_idea"
      },
      "description": "次に試す AB テスト仮説（任意）"
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_item"
      },
      "description": "提案の根拠ソース一覧"
    },
    "target_hypothesis": {
      "type": "string",
      "minLength": 1,
      "description": "想定ターゲットの仮説"
    },
    "message_angle": {
      "type": "string",
      "minLength": 1,
      "description": "訴求軸の要約"
    },
    "rubric_scores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rubric_score"
      },
      "description": "rubric 各項目のスコア"
    },
    "one_pager_sections": {
      "$ref": "one-pager-schema.json",
      "description": "1 枚資料用セクション（任意）"
    },
    "visible_text_elements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/visible_text_element"
      },
      "description": "画像から抽出されたテキスト要素（バナー生成時のテキスト保持用）"
    },
    "category_context": {
      "$ref": "#/$defs/category_context",
      "description": "業界カテゴリコンテキスト（推定・任意）"
    },
    "value_proposition_analysis": {
      "$ref": "#/$defs/value_proposition_analysis",
      "description": "価格・インセンティブ分析（条件付き・任意）"
    }
  },
  "additionalProperties": false,
  "if": {
    "properties": { "review_type": { "const": "banner_review" } }
  },
  "then": {
    "properties": {
      "rubric_scores": {
        "description": "banner_review は以下の 5 rubric ID を各1回ずつ全て含む必要がある。",
        "minItems": 5,
        "maxItems": 5,
        "items": {
          "properties": {
            "rubric_id": {
              "enum": [
                "visual_impact",
                "message_clarity",
                "cta_effectiveness",
                "brand_consistency",
                "information_balance"
              ]
            }
          }
        },
        "allOf": [
          { "contains": { "properties": { "rubric_id": { "const": "visual_impact" } }, "required": ["rubric_id"] } },
          { "contains": { "properties": { "rubric_id": { "const": "message_clarity" } }, "required": ["rubric_id"] } },
          { "contains": { "properties": { "rubric_id": { "const": "cta_effectiveness" } }, "required": ["rubric_id"] } },
          { "contains": { "properties": { "rubric_id": { "const": "brand_consistency" } }, "required": ["rubric_id"] } },
          { "contains": { "properties": { "rubric_id": { "const": "information_balance" } }, "required": ["rubric_id"] } }
        ]
      }
    }
  },
  "else": {
    "if": {
      "properties": { "review_type": { "const": "ad_lp_review" } }
    },
    "then": {
      "properties": {
        "rubric_scores": {
          "description": "ad_lp_review は以下の 8 rubric ID を各1回ずつ全て含む必要がある。enum + minItems/maxItems=8 で重複排除、allOf/contains で per-ID presence を保証。",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "properties": {
              "rubric_id": {
                "enum": [
                  "first_view_clarity",
                  "ad_to_lp_message_match",
                  "benefit_clarity",
                  "trust_elements",
                  "cta_placement",
                  "drop_off_risk",
                  "input_friction",
                  "story_consistency"
                ]
              }
            }
          },
          "allOf": [
            { "contains": { "properties": { "rubric_id": { "const": "first_view_clarity" } }, "required": ["rubric_id"] } },
            { "contains": { "properties": { "rubric_id": { "const": "ad_to_lp_message_match" } }, "required": ["rubric_id"] } },
            { "contains": { "properties": { "rubric_id": { "const": "benefit_clarity" } }, "required": ["rubric_id"] } },
            { "contains": { "properties": { "rubric_id": { "const": "trust_elements" } }, "required": ["rubric_id"] } },
            { "contains": { "properties": { "rubric_id": { "const": "cta_placement" } }, "required": ["rubric_id"] } },
            { "contains": { "properties": { "rubric_id": { "const": "drop_off_risk" } }, "required": ["rubric_id"] } },
            { "contains": { "properties": { "rubric_id": { "const": "input_friction" } }, "required": ["rubric_id"] } },
            { "contains": { "properties": { "rubric_id": { "const": "story_consistency" } }, "required": ["rubric_id"] } }
          ]
        }
      }
    }
  },
  "_rubric_contract": {
    "description": "Runtime source of truth: web/app/services/review/review_prompt_builder.py の BANNER_RUBRIC_IDS / LP_RUBRIC_IDS。review_output_validator.py がこれを参照して completeness + membership を検証する。この schema の if/then は同じ ID set を反映している。",
    "banner_review_rubric_ids": [
      "visual_impact", "message_clarity", "cta_effectiveness",
      "brand_consistency", "information_balance"
    ],
    "ad_lp_review_rubric_ids": [
      "first_view_clarity", "ad_to_lp_message_match", "benefit_clarity", "trust_elements",
      "cta_placement", "drop_off_risk", "input_friction", "story_consistency"
    ]
  },
  "$defs": {
    "review_point": {
      "type": "object",
      "required": ["point", "reason"],
      "properties": {
        "point": {
          "type": "string",
          "minLength": 1,
          "description": "指摘内容"
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "description": "根拠や理由"
        }
      },
      "additionalProperties": false
    },
    "improvement_point": {
      "type": "object",
      "required": ["point", "reason", "action"],
      "properties": {
        "point": {
          "type": "string",
          "minLength": 1,
          "description": "改善点の概要"
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "description": "なぜ改善すべきか"
        },
        "action": {
          "type": "string",
          "minLength": 1,
          "description": "具体的な行動ステップ"
        }
      },
      "additionalProperties": false
    },
    "test_idea": {
      "type": "object",
      "required": ["hypothesis", "variable", "expected_impact"],
      "properties": {
        "hypothesis": {
          "type": "string",
          "minLength": 1,
          "description": "テスト仮説"
        },
        "variable": {
          "type": "string",
          "minLength": 1,
          "description": "変更する変数"
        },
        "expected_impact": {
          "type": "string",
          "minLength": 1,
          "description": "期待される効果（仮説として表現）"
        }
      },
      "additionalProperties": false
    },
    "evidence_item": {
      "type": "object",
      "required": ["evidence_type", "evidence_source", "evidence_text"],
      "properties": {
        "evidence_type": {
          "type": "string",
          "enum": [
            "client_material",
            "approved_proposal",
            "winning_creative",
            "competitor_public",
            "platform_guideline"
          ],
          "description": "ソース種別"
        },
        "evidence_source": {
          "type": "string",
          "minLength": 1,
          "description": "出典元の名称または URL"
        },
        "evidence_text": {
          "type": "string",
          "minLength": 1,
          "description": "引用テキストまたは要約"
        }
      },
      "additionalProperties": false
    },
    "rubric_score": {
      "type": "object",
      "required": ["rubric_id", "score", "comment"],
      "properties": {
        "rubric_id": {
          "type": "string",
          "minLength": 1,
          "description": "rubric 項目 ID"
        },
        "score": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 5,
          "description": "1-5 スコア（評価不能時は null）"
        },
        "comment": {
          "type": "string",
          "minLength": 1,
          "description": "スコアの根拠コメント"
        }
      },
      "additionalProperties": false
    },
    "visible_text_element": {
      "type": "object",
      "required": ["role", "text"],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1,
          "enum": ["headline", "sub_copy", "cta", "price", "note", "brand_name"],
          "description": "テキスト要素の役割"
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "description": "画像に表示されている正確なテキスト"
        },
        "approximate_position": {
          "type": "string",
          "description": "要素のおおよその位置（top-left, center, bottom-right 等）"
        }
      },
      "additionalProperties": false
    },
    "category_context": {
      "type": "object",
      "required": ["inferred_category", "observations"],
      "properties": {
        "inferred_category": {
          "type": "string",
          "minLength": 1,
          "description": "推定された業界カテゴリ名"
        },
        "observations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "業界の広告傾向における位置づけ（1-2文）"
        }
      },
      "additionalProperties": false
    },
    "value_proposition_analysis": {
      "type": "object",
      "required": ["purchase_threshold", "incentive", "perceived_value_assessment", "communication_clarity"],
      "properties": {
        "purchase_threshold": {
          "type": "string",
          "minLength": 1,
          "description": "購入条件"
        },
        "incentive": {
          "type": "string",
          "minLength": 1,
          "description": "インセンティブ内容"
        },
        "perceived_value_assessment": {
          "type": "string",
          "minLength": 1,
          "description": "知覚価値の評価"
        },
        "communication_clarity": {
          "type": "string",
          "minLength": 1,
          "description": "伝達の明確さ"
        }
      },
      "additionalProperties": false
    }
  }
}
