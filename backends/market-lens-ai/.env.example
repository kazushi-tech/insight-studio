GEMINI_API_KEY=
# テキスト分析用モデル（安価モデル推奨）
GEMINI_ANALYSIS_MODEL=gemini-3.1-flash-lite-preview
# Vision / 画像系モデル（将来の Vision 機能用）
GEMINI_VISION_MODEL=gemini-3.1-flash-image-preview
# 互換 fallback（GEMINI_ANALYSIS_MODEL 未設定時に使用）
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=4096
ALLOWLIST_PATH=config/domain_allowlist.json
# Staging/Production: ALLOWLIST_JSON で JSON 文字列として allowlist を供給可能
# ALLOWLIST_JSON が設定されている場合、ALLOWLIST_PATH より優先される
# ALLOWLIST_JSON={"domains":[{"domain":"example.com","label":"Example","allowed":true,"robots_checked":true,"tos_checked":true}]}
BACKEND_PORT=8002
FRONTEND_PORT=3001
CORS_ORIGINS=http://localhost:3001
RATE_LIMIT_PER_MIN=10
# Integration API Keys (comma-separated) for webhook/import endpoints
# Leave empty to disable authentication (NOT recommended for production)
INTEGRATION_API_KEYS=
# Competitor URL Discovery — uses Gemini Search Grounding
# Discovery Model (default: gemini-3-flash-preview)
# GEMINI_DISCOVERY_MODEL=gemini-3-flash-preview
DISCOVERY_DAILY_LIMIT=100
