# Gemini API key (DO NOT put real key here)
# Set either one:
GEMINI_API_KEY=YOUR_KEY_HERE
# GOOGLE_API_KEY=YOUR_KEY_HERE

# Client-key mode (default: true)
# true = ユーザーが UI で自分の API キーを入力（サーバー側キー不要）
# false = サーバー側 GEMINI_API_KEY を全ユーザーで共用
GEMINI_REQUIRE_CLIENT_KEY=true

# Google Drive sync folder path (optional)
# If set, data will be read from this folder instead of ./data
# DRIVE_ROOT=G:\マイドライブ\ads-insights\data

# ================================================
# Google Drive API Integration (Optional)
# ================================================
# Get these from Google Cloud Console:
# 1. Create a project at https://console.cloud.google.com/
# 2. Enable "Google Drive API" and "Google Picker API"
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Create API Key

# OAuth 2.0 Client ID (from Credentials page)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# API Key for Picker (from Credentials page)  
GOOGLE_PICKER_API_KEY=your-api-key

# GCP Project Number (from Project Settings)
GOOGLE_APP_ID=123456789012

# ================================================
# Data Provider Configuration
# ================================================
# Choose data source: excel (default), mock, ga4
# - excel: Read from Excel files in ./data folder or Google Drive
# - mock: Use fixed sample data (for testing without Excel files)
# - ga4: Google Analytics 4 API (not implemented yet)
DATA_PROVIDER=excel

# Week start day for single-date weekly reports (monday or sunday)
# - monday: ISO week standard (Mon-Sun) - default
# - sunday: US standard (Sun-Sat)
WEEK_START_DAY=monday

# Debug mode for KPI extraction (shows column names and mapping results)
# Set to true when testing new Excel file formats
# DEBUG_KPI_EXTRACTION=true

# ================================================
# LLM Model Selection (Ad-Ops Skills)
# ================================================
# gemini-flash (default) / claude-haiku / claude-sonnet
ANALYSIS_MODEL=gemini-flash

# Claude API（将来用）
# ANTHROPIC_API_KEY=YOUR_KEY_HERE

# ================================================
# BigQuery Authentication (V2.9)
# ================================================
# Service account key JSON → Base64 encoded
# For production (Render): Set this environment variable in dashboard
# For local dev: Use `gcloud auth application-default login` instead (ADC)
#
# How to generate:
#   PowerShell: [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((Get-Content -Path "key.json" -Raw))) | Set-Clipboard
#   Bash:       base64 -w0 key.json | xclip -selection clipboard
# GOOGLE_CREDENTIALS_JSON=BASE64_ENCODED_SERVICE_ACCOUNT_KEY

# GCP Project ID for BigQuery queries
GCP_PROJECT_ID=analyzedataplatform

# ================================================
# Security & Rate Limiting (V2.6)
# ================================================
# Additional allowed CORS origins (comma-separated)
# CORS_ALLOWED_ORIGINS=https://your-domain.com,https://other-domain.com

# Rate limiting: max requests per window per client
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=60

# App password for login gate (REQUIRED — no default)
APP_PASSWORD=your-secure-password-here

# Enable debug endpoints (/api/debug/*, /api/version)
# Default: false — set to true only for local development
# ENABLE_DEBUG_ENDPOINTS=true
